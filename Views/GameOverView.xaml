<UserControl x:Class="RPG_Game_Elfshock.Views.GameOverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="Black">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- GAME OVER: fades + scales in dramatically -->
            <TextBlock Text="GAME OVER"
                       Foreground="#FFE0403A"
                       FontFamily="Consolas"
                       FontSize="52"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <ScaleTransform x:Name="GoScale" ScaleX="0.6" ScaleY="0.6" />
                </TextBlock.RenderTransform>
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.6" />
                                <DoubleAnimation Storyboard.TargetName="GoScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 From="0.6" To="1" Duration="0:0:0.7">
                                    <DoubleAnimation.EasingFunction>
                                        <BackEase EasingMode="EaseOut" Amplitude="0.6" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="GoScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 From="0.6" To="1" Duration="0:0:0.7">
                                    <DoubleAnimation.EasingFunction>
                                        <BackEase EasingMode="EaseOut" Amplitude="0.6" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>

            <TextBlock Text="Your hero was slain."
                       Foreground="#FFBBBBBB"
                       FontFamily="Consolas"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,0" />

            <TextBlock Text="{Binding ScoreText}"
                       Foreground="#FFEEDD55"
                       FontFamily="Consolas"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0" />

            <!-- Prompt: blinks to draw attention -->
            <TextBlock Text="Press any key to play again"
                       Foreground="#FFAAAAAA"
                       FontFamily="Consolas"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Margin="0,32,0,0">
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1" To="0.15" Duration="0:0:0.9" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
