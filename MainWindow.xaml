<Window x:Class="RPG_Game_Elfshock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RPG_Game_Elfshock.ViewModels"
        xmlns:views="clr-namespace:RPG_Game_Elfshock.Views"
        xmlns:controls="clr-namespace:RPG_Game_Elfshock.Controls"
        Title="Elfshock RPG" Height="640" Width="560"
        Background="Black"
        KeyDown="Window_OnKeyDown">

    <Window.Resources>
        <!-- Map each screen view model to its view -->
        <DataTemplate DataType="{x:Type vm:MainMenuViewModel}">
            <views:MainMenuView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CharacterSelectViewModel}">
            <views:CharacterSelectView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:InGameViewModel}">
            <views:InGameView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GameOverViewModel}">
            <views:GameOverView />
        </DataTemplate>

        <!-- Red pulse played over the whole window when the hero takes damage -->
        <Storyboard x:Key="DamageFlash">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DamageOverlay"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame Value="0.0" KeyTime="0:0:0.00" />
                <LinearDoubleKeyFrame Value="0.55" KeyTime="0:0:0.08" />
                <LinearDoubleKeyFrame Value="0.0" KeyTime="0:0:0.26" />
                <LinearDoubleKeyFrame Value="0.30" KeyTime="0:0:0.34" />
                <LinearDoubleKeyFrame Value="0.0" KeyTime="0:0:0.55" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <controls:TransitioningContentControl Content="{Binding Current}"
                                              RenderTransformOrigin="0.5,0.5" />

        <!-- Full-window red overlay; invisible until a hit pulses it -->
        <Border x:Name="DamageOverlay"
                Background="#FFCC0000"
                Opacity="0"
                IsHitTestVisible="False" />
    </Grid>
</Window>
