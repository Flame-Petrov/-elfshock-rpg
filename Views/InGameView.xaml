<UserControl x:Class="RPG_Game_Elfshock.Views.InGameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Background="Black" LastChildFill="True">
        <!-- Health / Mana / Kills shown above the field -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding StatusText}"
                   Foreground="#FF66FF66"
                   FontFamily="Consolas"
                   FontSize="18"
                   Margin="12,12,12,0" />

        <!-- Primary stats: STR / AGI / INT / Range -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding StatsText}"
                   Foreground="#FFBFC7D5"
                   FontFamily="Consolas"
                   FontSize="15"
                   Margin="12,4,12,12" />

        <!-- Options for this turn shown below the field -->
        <StackPanel DockPanel.Dock="Bottom" Margin="12">
            <TextBlock Text="{Binding OptionsText}"
                       Foreground="#FFDDDDDD"
                       FontFamily="Consolas"
                       FontSize="15" />
            <TextBlock Text="{Binding Message}"
                       Foreground="#FFFF8866"
                       FontFamily="Consolas"
                       FontSize="15"
                       Margin="0,8,0,0" />
        </StackPanel>

        <!-- The battlefield as a 10x10 grid so the target can be highlighted -->
        <ItemsControl ItemsSource="{Binding Cells}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="10" Columns="10" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="Cell"
                            Width="30"
                            Height="30"
                            CornerRadius="3"
                            BorderThickness="0"
                            BorderBrush="Transparent"
                            Background="Transparent">
                        <Grid>
                            <!-- Purple blast overlay (mage area damage) -->
                            <Border x:Name="Blast"
                                    CornerRadius="3"
                                    Background="#FF9B30FF"
                                    Opacity="0" />
                            <!-- Cyan arrow-hit overlay (archer ricochet) -->
                            <Border x:Name="Arrow"
                                    CornerRadius="3"
                                    Background="#FF33CCFF"
                                    Opacity="0" />
                            <TextBlock x:Name="Sym"
                                       Text="{Binding Symbol}"
                                       Foreground="#FF555555"
                                       FontFamily="Consolas"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="SymShift" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </Border>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsMonster}" Value="True">
                            <Setter TargetName="Sym" Property="Foreground" Value="#FFDD6666" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsHero}" Value="True">
                            <Setter TargetName="Sym" Property="Foreground" Value="#FF66FF66" />
                            <Setter TargetName="Sym" Property="FontWeight" Value="Bold" />
                        </DataTrigger>
                        <!-- A stat pickup: glowing green, gently pulsing -->
                        <DataTrigger Binding="{Binding IsPickup}" Value="True">
                            <Setter TargetName="Sym" Property="Foreground" Value="#FF66FF99" />
                            <Setter TargetName="Sym" Property="FontWeight" Value="Bold" />
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="Sym"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0.5" To="1.0"
                                                         Duration="0:0:0.6" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                        <!-- The monster currently targeted for attack -->
                        <DataTrigger Binding="{Binding IsSelectedTarget}" Value="True">
                            <Setter TargetName="Cell" Property="Background" Value="#55EEDD55" />
                            <Setter TargetName="Sym" Property="Foreground" Value="#FFFFF2A0" />
                            <Setter TargetName="Sym" Property="FontWeight" Value="Bold" />
                        </DataTrigger>
                        <!-- A monster the archer chain will kill -->
                        <DataTrigger Binding="{Binding IsDoomed}" Value="True">
                            <Setter TargetName="Cell" Property="BorderBrush" Value="#FFFF3030" />
                            <Setter TargetName="Cell" Property="BorderThickness" Value="2" />
                            <Setter TargetName="Sym" Property="Foreground" Value="#FFFF6060" />
                            <Setter TargetName="Sym" Property="FontWeight" Value="Bold" />
                        </DataTrigger>
                        <!-- The mage's blast: blink the cell purple -->
                        <DataTrigger Binding="{Binding IsBlast}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="Blast"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0.15" To="0.85"
                                                         Duration="0:0:0.16" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                        <!-- The next monster the arrow will fly to: pulse it cyan -->
                        <DataTrigger Binding="{Binding IsArrowNext}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="Arrow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0.12" To="0.6"
                                                         Duration="0:0:0.25" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                        <!-- The monster being struck this step: shake it (cyan) -->
                        <DataTrigger Binding="{Binding IsArrowHit}" Value="True">
                            <Setter TargetName="Sym" Property="Foreground" Value="#FF66E0FF" />
                            <Setter TargetName="Sym" Property="FontWeight" Value="Bold" />
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SymShift"
                                                                       Storyboard.TargetProperty="X">
                                            <LinearDoubleKeyFrame Value="0"  KeyTime="0:0:0.00" />
                                            <LinearDoubleKeyFrame Value="-4" KeyTime="0:0:0.05" />
                                            <LinearDoubleKeyFrame Value="4"  KeyTime="0:0:0.12" />
                                            <LinearDoubleKeyFrame Value="-3" KeyTime="0:0:0.18" />
                                            <LinearDoubleKeyFrame Value="3"  KeyTime="0:0:0.23" />
                                            <LinearDoubleKeyFrame Value="0"  KeyTime="0:0:0.28" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</UserControl>
