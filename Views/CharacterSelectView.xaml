<UserControl x:Class="RPG_Game_Elfshock.Views.CharacterSelectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RPG_Game_Elfshock.Controls">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid Background="Black">
        <StackPanel Margin="30" VerticalAlignment="Center">
            <TextBlock Text="CHARACTER SELECT"
                       Foreground="#FFEEDD55"
                       FontFamily="Consolas"
                       FontSize="22"
                       Margin="0,0,0,18" />

            <!-- Stepped progress bar: Class -> Strength -> Agility -> Intelligence -->
            <ItemsControl ItemsSource="{Binding Steps}" Margin="0,0,0,22">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Width="112" Margin="0,0,6,0">
                            <Border x:Name="Bar"
                                    Height="8"
                                    CornerRadius="4"
                                    Background="#FF3A3A3A" />
                            <TextBlock x:Name="Lbl"
                                       Text="{Binding Label}"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       Foreground="#FF777777"
                                       Margin="0,6,0,0"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <DataTemplate.Triggers>
                            <!-- Completed steps -->
                            <DataTrigger Binding="{Binding IsDone}" Value="True">
                                <Setter TargetName="Bar" Property="Background" Value="#FF55CC77" />
                                <Setter TargetName="Lbl" Property="Foreground" Value="#FF55CC77" />
                            </DataTrigger>
                            <!-- The step the player is on -->
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                <Setter TargetName="Bar" Property="Background" Value="#FFEEDD55" />
                                <Setter TargetName="Lbl" Property="Foreground" Value="#FFEEDD55" />
                                <Setter TargetName="Lbl" Property="FontWeight" Value="Bold" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- The prompt animates (fade + slide) each time the choice changes -->
            <controls:TransitioningContentControl Content="{Binding Prompt}"
                                                  Foreground="#FFDDDDDD"
                                                  FontFamily="Consolas"
                                                  FontSize="16"
                                                  HorizontalContentAlignment="Left"
                                                  HorizontalAlignment="Left" />

            <!-- Class menu: move the arrow with Up/Down or W/S (class step only) -->
            <ItemsControl ItemsSource="{Binding ClassOptions}"
                          Margin="0,14,0,0"
                          Visibility="{Binding IsChoosingClass, Converter={StaticResource BoolToVis}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="Arrow"
                                       Grid.Column="0"
                                       Text=""
                                       Foreground="#FFEEDD55"
                                       FontFamily="Consolas"
                                       FontSize="16" />
                            <TextBlock x:Name="Name"
                                       Grid.Column="1"
                                       Text="{Binding Name}"
                                       Foreground="#FFBBBBBB"
                                       FontFamily="Consolas"
                                       FontSize="16" />
                            <TextBlock x:Name="Stats"
                                       Grid.Column="2"
                                       Text="{Binding Stats}"
                                       Foreground="#FF777777"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Arrow" Property="Text" Value="▶" />
                                <Setter TargetName="Name" Property="Foreground" Value="#FFEEDD55" />
                                <Setter TargetName="Name" Property="FontWeight" Value="Bold" />
                                <Setter TargetName="Stats" Property="Foreground" Value="#FFBBBBBB" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Input line for buff steps: blinking arrow + the typed number -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,16,0,0"
                        Visibility="{Binding IsBuffing, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="▶"
                           Foreground="#FFEEDD55"
                           FontFamily="Consolas"
                           FontSize="16"
                           Margin="0,0,8,0">
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1" To="0"
                                                     Duration="0:0:0.6" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
                <TextBlock Text="{Binding Input}"
                           Foreground="#FFFFFFFF"
                           FontFamily="Consolas"
                           FontSize="16"
                           MinWidth="20" />
            </StackPanel>

            <!-- Help about the current step's controls (hidden when empty) -->
            <TextBlock Text="{Binding Help}"
                       Foreground="#FF6B7686"
                       FontFamily="Consolas"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Help}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Text="{Binding Info}"
                       Foreground="#FF88CCFF"
                       FontFamily="Consolas"
                       FontSize="14"
                       Margin="0,18,0,0" />

            <!-- The highlighted class's special effect (shown while choosing) -->
            <Border Margin="0,18,0,0"
                    Padding="14,10"
                    CornerRadius="6"
                    Background="#FF1A1326"
                    BorderBrush="#FF50407A"
                    BorderThickness="1"
                    Visibility="{Binding IsChoosingClass, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding SelectedClassSpecial}"
                           Foreground="#FFC9B6F2"
                           FontFamily="Consolas"
                           FontSize="13"
                           TextWrapping="Wrap" />
            </Border>

            <!-- The player's choices so far, shown under everything -->
            <Border Margin="0,24,0,0"
                    Padding="14,10"
                    CornerRadius="6"
                    Background="#FF101820"
                    BorderBrush="#FF2A3A4A"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ClassLine}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="YOUR SELECTION"
                               Foreground="#FF8A93A3"
                               FontFamily="Consolas"
                               FontSize="12"
                               Margin="0,0,0,6" />
                    <TextBlock Text="{Binding ClassLine}"
                               Foreground="#FFCBD3E0"
                               FontFamily="Consolas"
                               FontSize="14" />

                    <!-- One chip per stat; green only when the player added points -->
                    <ItemsControl ItemsSource="{Binding Stats}" Margin="0,8,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock x:Name="StatText"
                                           Text="{Binding Text}"
                                           Foreground="#FFCBD3E0"
                                           FontFamily="Consolas"
                                           FontSize="14"
                                           Margin="0,0,18,0" />
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding HasPoints}" Value="True">
                                        <Setter TargetName="StatText" Property="Foreground" Value="#FF55CC77" />
                                        <Setter TargetName="StatText" Property="FontWeight" Value="Bold" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
